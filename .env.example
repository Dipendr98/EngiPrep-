# Copy this file to .env and adjust values as needed

# Pollinations API (https://gen.pollinations.ai) — no API key required.
# The default base URL and model are set in config.py.
# Override them here if needed:
# OPENAI_BASE_URL=https://gen.pollinations.ai/v1
# CHAT_MODEL=claude-large

# Optional: If you supply an OpenAI API key the client will send it,
# but the Pollinations API does not require one.
# OPENAI_API_KEY=your-api-key-here