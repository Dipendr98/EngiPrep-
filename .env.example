# AI Provider Configuration
# Default: Pollinations AI (free, no API key required)
OPENAI_BASE_URL=https://text.pollinations.ai/openai
OPENAI_MODEL=openai
OPENAI_API_KEY=pollinations

# To use OpenAI instead:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-key-here

# To use OpenRouter (100+ models):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=anthropic/claude-sonnet-4-20250514
# OPENAI_API_KEY=sk-or-your-key-here

# To use Groq (ultra-fast):
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-70b-versatile
# OPENAI_API_KEY=gsk_your-key-here